{
  "name": "herdr-orchestrate",
  "version": "0.0.0",
  "description": "Pi-native orchestration for visible Herdr worker sessions.",
  "homepage": "https://github.com/darjss/herdr-orchestrate#readme",
  "bugs": {
    "url": "https://github.com/darjss/herdr-orchestrate/issues"
  },
  "license": "MIT",
  "author": "darjss",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darjss/herdr-orchestrate.git"
  },
  "bin": {
    "orch": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./plugin-pane": "./dist/plugin-pane.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack src/index.ts src/cli.ts src/plugin-pane.ts --format esm --dts",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.14"
}
